{
  "name": "timestamplab-cli",
  "version": "0.1.1",
  "description": "Command-line tools for timestamp operations",
  "bin": {
    "tsl": "dist/cli.js",
    "timestamplab": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format cjs --dts",
    "dev": "tsup src/cli.ts src/index.ts --format cjs --dts --watch",
    "test": "vitest",
    "lint": "eslint src"
  },
  "keywords": [
    "timestamp",
    "cli",
    "converter",
    "unix",
    "time"
  ],
  "author": "TimestampLab",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "timestamplab-core": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/timestamplab",
    "directory": "packages/cli"
  }
}
