{
  "name": "@timestamplab/react",
  "version": "0.1.0",
  "description": "React components for timestamp conversion and display",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external react --external react-dom",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react --external react-dom",
    "test": "vitest",
    "lint": "eslint src"
  },
  "keywords": [
    "timestamp",
    "react",
    "components",
    "converter",
    "world-clock",
    "time-calculator"
  ],
  "author": "TimestampLab",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@timestamplab/core": "file:../core"
  },
  "devDependencies": {
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/timestamplab",
    "directory": "packages/react"
  }
}
