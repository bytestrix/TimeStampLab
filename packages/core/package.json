{
  "name": "timestamplab-core",
  "version": "0.1.0",
  "description": "Lightweight timestamp utilities with auto-detection",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "lint": "eslint src"
  },
  "keywords": [
    "timestamp",
    "date",
    "time",
    "unix",
    "milliseconds",
    "converter",
    "auto-detect",
    "lightweight"
  ],
  "author": "TimestampLab",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/timestamplab"
  },
  "bugs": {
    "url": "https://github.com/yourusername/timestamplab/issues"
  },
  "homepage": "https://timestamplab.dev"
}
